<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.snw.agent-linkd</string>
  <key>ProgramArguments</key>
  <array>
    <string>__SNW_AGENT_LINKD_BIN__</string>
    <string>--data-dir</string><string>__SNW_AGENT_LINK_DATA_DIR__</string>
    <string>--tailscale-bind-ip</string><string>__TAILSCALE_BIND_IP__</string>
    <string>--gateway-port</string><string>7443</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>ProcessType</key><string>Interactive</string>
  <key>HardResourceLimits</key>
  <dict><key>NumberOfFiles</key><integer>4096</integer></dict>
  <key>StandardOutPath</key><string>__SNW_AGENT_LINK_DATA_DIR__/daemon.stdout.log</string>
  <key>StandardErrorPath</key><string>__SNW_AGENT_LINK_DATA_DIR__/daemon.stderr.log</string>
</dict>
</plist>
